import { Button, LineEdit, HorizontalBox, VerticalBox, CheckBox, ListView, SpinBox, ScrollView, ComboBox } from "std-widgets.slint";

global Tokens {
    // Background colors - Premium dark theme
    out property <color> bg-window: #0a0a0b;
    out property <color> bg-surface: #111113;
    out property <color> bg-sidebar: #0e0e10;
    out property <color> bg-toolbar: #0a0a0b;
    out property <color> bg-header: #111113;
    out property <color> bg-status: #0a0a0b;
    out property <color> bg-row-alt: #0e0e10;
    out property <color> bg-hover: #1a1a1c;
    out property <color> bg-selected: #c9a22740;
    out property <color> bg-selected-hover: #c9a22760;
    out property <color> bg-input: #111113;

    // Brand colors - Luxurious gold accent
    out property <color> primary: #c9a227;
    out property <color> secondary: #d4b84a;
    out property <color> accent: #e8d48a;
    out property <color> primary-soft: #c9a22730;
    out property <color> primary-hover: #d4b84a;

    // Text colors - Warm whites
    out property <color> text-primary: #e4e4e7;
    out property <color> text-secondary: #a1a1aa;
    out property <color> text-tertiary: #71717a;
    out property <color> text-on-primary: #0a0a0b;
    out property <color> text-header: #c9a227;

    // Borders - Subtle and refined
    out property <color> border: #27272a;
    out property <color> border-subtle: #1f1f22;
    out property <color> border-focus: #c9a227;

    // Typography - Inter with refined scale
    out property <length> font-xs: 11px;
    out property <length> font-sm: 13px;
    out property <length> font-md: 14px;
    out property <length> font-lg: 15px;
}

export struct FileEntry {
    name: string,
    path: string,
    is-dir: bool,
    size: string,
    modified: string,
    icon: string,
    selected: bool,
}

export struct SidebarItem {
    name: string,
    icon: string,
    path: string,
    section: string,
}

component StyledButton {
    in property <string> text: "";
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> compact: false;
    callback clicked();

    min-height: 36px;
    max-height: 40px;
    min-width: 36px;
    max-width: 140px;

    TouchArea {
        enabled: root.enabled;
        mouse-cursor: enabled ? pointer : default;
        clicked => { root.clicked() }

        Rectangle {
            border-radius: 8px;
            background: root.primary ? Tokens.primary : (root.enabled ? Tokens.bg-surface : Tokens.bg-row-alt);

            // Subtle border
            Rectangle {
                x: 0; y: 0; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: 0; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }

            Text {
                text: root.text;
                font-family: "Inter";
                font-size: root.compact ? Tokens.font-xs : Tokens.font-sm;
                font-weight: root.primary ? 600 : 500;
                color: root.primary ? Tokens.text-on-primary : (root.enabled ? Tokens.text-secondary : Tokens.text-tertiary);
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component StyledInput {
    in property <string> text: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    in-out property <string> value: root.text;
    callback accepted(string);
    callback edited(string);

    min-height: 36px;
    max-height: 40px;

    Rectangle {
        background: Tokens.bg-input;
        border-radius: 8px;

        // Subtle border
        Rectangle {
            x: 0; y: 0; width: parent.width; height: 1px;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: 0; y: 0; width: 1px; height: parent.height;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
            background: Tokens.border-subtle;
        }

        LineEdit {
            text: root.text;
            placeholder-text: root.placeholder;
            enabled: root.enabled;
            horizontal-stretch: 1;
            font-family: "Inter";
            font-size: Tokens.font-sm;
            accepted(text) => { root.accepted(text) }
            edited(text) => { root.edited(text) }
        }
    }
}

component Sidebar {
    in property <[SidebarItem]> items;
    in property <string> active-path;
    callback item-clicked(string);

    min-width: 200px;
    max-width: 260px;
    preferred-width: 220px;

    Rectangle {
        background: Tokens.bg-sidebar;

        VerticalBox {
            padding: 20px;
            spacing: 6px;

            // Favorites section header
            Text {
                text: "FAVORITES";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: 600;
                color: Tokens.text-tertiary;
                letter-spacing: 1px;
            }

            for item in root.items : TouchArea {
                visible: item.section == "favorites";
                height: 40px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 8px;

                    HorizontalBox {
                        padding-left: 14px;
                        spacing: 12px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: item.path == root.active-path ? 500 : 400;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle { min-height: 24px; max-height: 24px; }

            // Devices section header
            Text {
                text: "DEVICES";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: 600;
                color: Tokens.text-tertiary;
                letter-spacing: 1px;
            }

            for item in root.items : TouchArea {
                visible: item.section == "devices";
                height: 40px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 8px;

                    HorizontalBox {
                        padding-left: 14px;
                        spacing: 12px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: item.path == root.active-path ? 500 : 400;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component Toolbar {
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> search-text;

    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);
    callback settings-clicked();
    callback shortcuts-clicked();

    min-height: 50px;
    max-height: 54px;
    preferred-height: 52px;

    Rectangle {
        background: Tokens.bg-toolbar;

        // Subtle bottom shadow
        Rectangle {
            y: parent.height - 4px;
            height: 4px;
            background: #00000030;
        }

        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding: 10px;
            spacing: 10px;

            StyledButton {
                text: "←";
                compact: true;
                enabled: root.can-go-back;
                clicked => { root.go-back() }
            }
            StyledButton {
                text: "→";
                compact: true;
                enabled: root.can-go-forward;
                clicked => { root.go-forward() }
            }
            StyledButton {
                text: "↑";
                compact: true;
                clicked => { root.go-up() }
            }

            Rectangle { width: 1px; background: Tokens.border-subtle; }

            StyledInput {
                text: root.current-path;
                placeholder: "Path...";
                accepted(text) => { root.path-entered(text) }
                horizontal-stretch: 1;
            }

            StyledInput {
                text: root.search-text;
                placeholder: "Search files...";
                edited(text) => { root.search-changed(text) }
                min-width: 180px;
                max-width: 240px;
            }

            // Spacer
            Rectangle { horizontal-stretch: 1; }

            StyledButton {
                text: "?";
                compact: true;
                clicked => { root.shortcuts-clicked() }
            }

            StyledButton {
                text: "⚙";
                compact: true;
                clicked => { root.settings-clicked() }
            }
        }
    }
}

component FileList {
    in property <[FileEntry]> files;
    in property <[int]> selected-indices: [];

    callback file-selected(int, bool, bool);  // index, ctrl-pressed, shift-pressed
    callback file-activated(int);
    callback sort-requested(string);

    VerticalBox {
        padding: 0;
        spacing: 0;

        Rectangle {
            min-height: 40px;
            max-height: 44px;
            background: Tokens.bg-header;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: 100%;
                background: Tokens.border-subtle;
            }

            HorizontalBox {
                padding-left: 16px;
                padding-right: 16px;
                spacing: 12px;

                TouchArea {
                    horizontal-stretch: 3;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("name") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        padding: 6px;
                        Text {
                            text: "Name";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: 600;
                            color: Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                        }
                    }
                }

                TouchArea {
                    horizontal-stretch: 0;
                    min-width: 90px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("size") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        padding: 6px;
                        Text {
                            text: "Size";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: 600;
                            color: Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                        }
                    }
                }

                TouchArea {
                    horizontal-stretch: 0;
                    min-width: 140px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("modified") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        padding: 6px;
                        Text {
                            text: "Modified";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: 600;
                            color: Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                        }
                    }
                }
            }
        }

        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            for entry[index] in root.files : TouchArea {
                min-height: 38px;
                max-height: 42px;
                mouse-cursor: pointer;
                clicked => { 
                    root.file-selected(index, false, false) 
                }

                // Selection background with subtle alternating row colors
                Rectangle {
                    width: 100%;
                    height: 100%;
                    background: entry.selected ? Tokens.bg-selected : (mod(index, 2) == 0 ? Tokens.bg-window : Tokens.bg-row-alt);
                    border-radius: 6px;
                }

                HorizontalBox {
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 12px;

                    HorizontalBox {
                        horizontal-stretch: 3;
                        spacing: 12px;
                        Text {
                            text: entry.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: entry.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            color: entry.selected ? Tokens.text-primary : Tokens.text-primary;
                            font-weight: entry.selected ? 500 : 400;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        min-width: 90px;
                        horizontal-stretch: 0;
                        text: entry.size;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: entry.selected ? Tokens.text-secondary : Tokens.text-secondary;
                        vertical-alignment: center;
                    }

                    Text {
                        min-width: 140px;
                        horizontal-stretch: 0;
                        text: entry.modified;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: entry.selected ? Tokens.text-secondary : Tokens.text-secondary;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component StatusBar {
    in property <int> item-count;
    in property <string> status-message;

    min-height: 32px;
    max-height: 36px;
    preferred-height: 34px;

    Rectangle {
        background: Tokens.bg-status;

        // Subtle top shadow
        Rectangle {
            y: 0;
            height: 4px;
            width: 100%;
            background: #00000015;
        }

        Rectangle {
            y: 4px;
            height: 1px;
            width: 100%;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding-left: 20px;
            padding-right: 20px;

            Text {
                text: "\{root.item-count} items";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: 500;
                color: Tokens.text-secondary;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: root.status-message;
                font-family: "Inter";
                font-size: Tokens.font-xs;
                color: Tokens.text-tertiary;
                horizontal-alignment: right;
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "felix";
    min-width: 640px;
    min-height: 420px;
    preferred-width: 960px;
    preferred-height: 640px;
    background: Tokens.bg-window;

    in property <string> current-path: "/home";
    in property <[FileEntry]> files: [];
    in property <[SidebarItem]> sidebar-items: [];
    in property <string> sidebar-active-path: "";
    in property <[int]> selected-indices: [];
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    in property <string> search-text: "";
    in property <string> status-message: "";

    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);
    callback sidebar-item-clicked(string);
    callback file-selected(int, bool, bool);
    callback file-activated(int);
    callback sort-requested(string);
    callback settings-clicked();
    callback shortcuts-clicked();

    VerticalBox {
        spacing: 0;

        Toolbar {
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            search-text: root.search-text;
            go-back => { root.go-back() }
            go-forward => { root.go-forward() }
            go-up => { root.go-up() }
            path-entered(p) => { root.path-entered(p) }
            search-changed(s) => { root.search-changed(s) }
            settings-clicked => { root.settings-clicked() }
            shortcuts-clicked => { root.shortcuts-clicked() }
        }

        HorizontalBox {
            spacing: 0;

            Sidebar {
                items: root.sidebar-items;
                active-path: root.sidebar-active-path;
                item-clicked(p) => { root.sidebar-item-clicked(p) }
            }

            Rectangle {
                width: 1px;
                background: Tokens.border;
            }

            FileList {
                files: root.files;
                selected-indices: root.selected-indices;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                file-selected(i, ctrl, shift) => { root.file-selected(i, ctrl, shift) }
                file-activated(i) => { root.file-activated(i) }
                sort-requested(col) => { root.sort-requested(col) }
            }
        }

        StatusBar {
            item-count: root.files.length;
            status-message: root.status-message;
        }
    }
}

export component SetupDialog inherits Dialog {
    title: "felix — First Launch";
    min-width: 400px;
    min-height: 320px;
    background: Tokens.bg-window;

    in-out property <bool> enable-markdown: true;
    in-out property <bool> enable-pdf: true;
    in-out property <bool> enable-docx: false;
    in-out property <bool> enable-pptx: false;

    callback setup-complete();

    VerticalBox {
        padding: 28px;
        spacing: 24px;

        Text {
            text: "Welcome to felix";
            font-family: "Inter";
            font-size: 20px;
            font-weight: 600;
            color: Tokens.text-primary;
        }

        Text {
            text: "Choose tools to enable:";
            font-family: "Inter";
            font-size: Tokens.font-md;
            color: Tokens.text-secondary;
        }

        VerticalBox {
            spacing: 14px;

            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-markdown; toggled => { root.enable-markdown = self.checked } }
                Text { text: "Markdown"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-pdf; toggled => { root.enable-pdf = self.checked } }
                Text { text: "PDF"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-docx; toggled => { root.enable-docx = self.checked } }
                Text { text: "DOCX"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-pptx; toggled => { root.enable-pptx = self.checked } }
                Text { text: "PPTX"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
        }

        Rectangle { vertical-stretch: 1; }

        StyledButton {
            text: "Get Started";
            primary: true;
            clicked => { root.setup-complete() }
        }
    }
}

export component SettingsDialog inherits Dialog {
    title: "felix — Settings";
    min-width: 560px;
    min-height: 580px;
    background: Tokens.bg-window;

    // General
    in-out property <bool> show-hidden: false;
    in-out property <bool> confirm-delete: true;
    in-out property <int> page-size: 100;

    // Theme
    in-out property <int> theme-mode: 0; // 0=System, 1=Light, 2=Dark
    in-out property <string> accent-color: "#c9a227";

    // Tools
    in-out property <bool> markdown-preview: true;
    in-out property <bool> pdf-preview: true;
    in-out property <bool> docx-preview: false;
    in-out property <bool> pptx-preview: false;

    // Sidebar
    in-out property <bool> show-devices: true;
    in-out property <bool> show-bookmarks: true;

    // Viewers
    in-out property <string> image-viewer: "imv";
    in-out property <string> video-viewer: "mpv";
    in-out property <string> pdf-viewer: "zathura";

    callback save-config();
    callback close-dialog();

    VerticalBox {
        padding: 24px;
        spacing: 16px;

        Text {
            text: "Settings";
            font-family: "Inter";
            font-size: 20px;
            font-weight: 600;
            color: Tokens.text-primary;
        }

        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            VerticalBox {
                padding: 4px;
                spacing: 20px;

                // ─── General ──────────────────────────────────────
                VerticalBox {
                    spacing: 12px;

                    Text {
                        text: "General";
                        font-family: "Inter";
                        font-size: Tokens.font-md;
                        font-weight: 600;
                        color: Tokens.primary;
                        letter-spacing: 0.5px;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.show-hidden; toggled => { root.show-hidden = self.checked } }
                        Text { text: "Show hidden files"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.confirm-delete; toggled => { root.confirm-delete = self.checked } }
                        Text { text: "Confirm before deleting"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Page size:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        SpinBox {
                            value: root.page-size;
                            minimum: 10;
                            maximum: 1000;
                            step-size: 10;
                            edited(value) => { root.page-size = value }
                        }
                    }
                }

                // ─── Theme ────────────────────────────────────────
                VerticalBox {
                    spacing: 12px;

                    Text {
                        text: "Theme";
                        font-family: "Inter";
                        font-size: Tokens.font-md;
                        font-weight: 600;
                        color: Tokens.primary;
                        letter-spacing: 0.5px;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Theme:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        ComboBox {
                            model: ["System", "Light", "Dark"];
                            current-index <=> root.theme-mode;
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Accent color:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.accent-color;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.accent-color = text }
                        }
                    }
                }

                // ─── Document Tools ───────────────────────────────
                VerticalBox {
                    spacing: 12px;

                    Text {
                        text: "Document Tools";
                        font-family: "Inter";
                        font-size: Tokens.font-md;
                        font-weight: 600;
                        color: Tokens.primary;
                        letter-spacing: 0.5px;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.markdown-preview; toggled => { root.markdown-preview = self.checked } }
                        Text { text: "Markdown preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.pdf-preview; toggled => { root.pdf-preview = self.checked } }
                        Text { text: "PDF preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.docx-preview; toggled => { root.docx-preview = self.checked } }
                        Text { text: "DOCX preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.pptx-preview; toggled => { root.pptx-preview = self.checked } }
                        Text { text: "PPTX preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }
                }

                // ─── Sidebar ──────────────────────────────────────
                VerticalBox {
                    spacing: 12px;

                    Text {
                        text: "Sidebar";
                        font-family: "Inter";
                        font-size: Tokens.font-md;
                        font-weight: 600;
                        color: Tokens.primary;
                        letter-spacing: 0.5px;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.show-devices; toggled => { root.show-devices = self.checked } }
                        Text { text: "Show devices"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        CheckBox { checked: root.show-bookmarks; toggled => { root.show-bookmarks = self.checked } }
                        Text { text: "Show bookmarks"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }
                }

                // ─── External Viewers ─────────────────────────────
                VerticalBox {
                    spacing: 12px;

                    Text {
                        text: "External Viewers";
                        font-family: "Inter";
                        font-size: Tokens.font-md;
                        font-weight: 600;
                        color: Tokens.primary;
                        letter-spacing: 0.5px;
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Images:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.image-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.image-viewer = text }
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "Video:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.video-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.video-viewer = text }
                        }
                    }

                    HorizontalBox {
                        spacing: 12px;
                        Text { text: "PDF:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.pdf-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.pdf-viewer = text }
                        }
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 14px;

            StyledButton {
                text: "Cancel";
                clicked => { root.close-dialog() }
            }

            Rectangle { horizontal-stretch: 1; }

            StyledButton {
                text: "Save";
                primary: true;
                clicked => { root.save-config() }
            }
        }
    }
}

export component ShortcutsDialog inherits Dialog {
    title: "felix — Keyboard Shortcuts";
    min-width: 440px;
    min-height: 520px;
    background: Tokens.bg-window;

    callback close();

    VerticalBox {
        padding: 24px;
        spacing: 20px;

        Text {
            text: "Keyboard Shortcuts";
            font-family: "Inter";
            font-size: 20px;
            font-weight: 600;
            color: Tokens.text-primary;
        }

        // Navigation
        Text {
            text: "Navigation";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: 600;
            color: Tokens.primary;
        }

        VerticalBox {
            spacing: 6px;
            HorizontalBox { Text { text: "Enter"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Open file or folder"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Backspace"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Go to parent directory"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "h"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Go back in history"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "l"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Go forward in history"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "j"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Select next file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "k"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Select previous file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
        }

        // Selection
        Text {
            text: "Selection";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: 600;
            color: Tokens.primary;
        }

        VerticalBox {
            spacing: 6px;
            HorizontalBox { Text { text: "Click"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Select single file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+Click"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Toggle selection"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Shift+Click"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Select range"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+Shift+Click"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Extend range"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+A"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Select all"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
        }

        // File Operations
        Text {
            text: "File Operations";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: 600;
            color: Tokens.primary;
        }

        VerticalBox {
            spacing: 6px;
            HorizontalBox { Text { text: "Delete"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Delete selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "F2"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Rename selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+C"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Copy selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+X"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Cut selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+V"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Paste"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
        }

        // Other
        Text {
            text: "Other";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: 600;
            color: Tokens.primary;
        }

        VerticalBox {
            spacing: 6px;
            HorizontalBox { Text { text: "Ctrl+F"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Focus search"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "Ctrl+,"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Open settings"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "?"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Show shortcuts"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
            HorizontalBox { Text { text: "F5"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; } Text { text: "Refresh"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: right; horizontal-stretch: 1; } }
        }

        Rectangle { vertical-stretch: 1; }

        StyledButton {
            text: "Close";
            primary: true;
            clicked => { root.close() }
        }
    }
}