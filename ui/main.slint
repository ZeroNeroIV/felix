import { Button, LineEdit, HorizontalBox, VerticalBox, CheckBox, ListView, SpinBox, ScrollView, ComboBox } from "std-widgets.slint";

export global Tokens {
    // Theme mode: 0=System, 1=Light, 2=Dark
    in-out property <int> theme-mode: 0;

    // Light mode colors - warm, soft whites (in-out for runtime overrides from Rust)
    in-out property <color> light-bg-window: #f5f5f0;
    in-out property <color> light-bg-surface: #fafaf5;
    in-out property <color> light-bg-sidebar: #eeeee8;
    in-out property <color> light-bg-toolbar: #fafaf5;
    in-out property <color> light-bg-header: #f5f5f0;
    in-out property <color> light-bg-status: #fafaf5;
    in-out property <color> light-bg-row-alt: #f0f0ea;
    in-out property <color> light-bg-hover: #e8e8e0;
    in-out property <color> light-bg-selected: #c9a22720;
    in-out property <color> light-bg-input: #fafaf5;
    in-out property <color> light-text-primary: #3a3a3c;
    in-out property <color> light-text-secondary: #5a5a5e;
    in-out property <color> light-text-tertiary: #8a8a8e;
    in-out property <color> light-text-on-primary: #ffffff;
    in-out property <color> light-border: #d8d8d0;
    in-out property <color> light-border-subtle: #e4e4dc;
    in-out property <color> light-shadow: #00000010;
    in-out property <color> light-bg-tab-active: #fafaf5;
    in-out property <color> light-bg-tab-inactive: #eeeee8;
    in-out property <color> light-text-tab-active: #3a3a3c;
    in-out property <color> light-text-tab-inactive: #8a8a8e;
    in-out property <color> light-border-column: #d8d8d0;
    in-out property <color> light-bg-column-active: #fafaf5;
    in-out property <color> light-bg-column-inactive: #f5f5f0;
    in-out property <color> light-bg-inspector: #fafaf5;
    in-out property <color> light-border-inspector: #d8d8d0;
    in-out property <color> light-shadow-inspector: #00000020;

    // Dark mode colors - soft navy darks (Catppuccin/Tokyo Night inspired) (in-out for runtime overrides from Rust)
    in-out property <color> dark-bg-window: #1a1b26;
    in-out property <color> dark-bg-surface: #1e1f2e;
    in-out property <color> dark-bg-sidebar: #161721;
    in-out property <color> dark-bg-toolbar: #1e1f2e;
    in-out property <color> dark-bg-header: #161721;
    in-out property <color> dark-bg-status: #1a1b26;
    in-out property <color> dark-bg-row-alt: #181926;
    in-out property <color> dark-bg-hover: #292e42;
    in-out property <color> dark-bg-selected: #c9a22730;
    in-out property <color> dark-bg-input: #1e1f2e;
    in-out property <color> dark-text-primary: #c0caf5;
    in-out property <color> dark-text-secondary: #a9b1d6;
    in-out property <color> dark-text-tertiary: #565f89;
    in-out property <color> dark-text-on-primary: #1a1b26;
    in-out property <color> dark-border: #2a2b3d;
    in-out property <color> dark-border-subtle: #22233a;
    in-out property <color> dark-shadow: #00000040;
    in-out property <color> dark-bg-tab-active: #1e1f2e;
    in-out property <color> dark-bg-tab-inactive: #161721;
    in-out property <color> dark-text-tab-active: #c0caf5;
    in-out property <color> dark-text-tab-inactive: #565f89;
    in-out property <color> dark-border-column: #2a2b3d;
    in-out property <color> dark-bg-column-active: #1e1f2e;
    in-out property <color> dark-bg-column-inactive: #1a1b26;
    in-out property <color> dark-bg-inspector: #1e1f2e;
    in-out property <color> dark-border-inspector: #2a2b3d;
    in-out property <color> dark-shadow-inspector: #00000080;

    // Active colors based on theme mode (with custom overrides via MainWindow properties)
    out property <color> bg-window: Tokens.theme-mode == 1 ? Tokens.light-bg-window : Tokens.dark-bg-window;
    out property <color> bg-surface: Tokens.theme-mode == 1 ? Tokens.light-bg-surface : Tokens.dark-bg-surface;
    out property <color> bg-sidebar: Tokens.theme-mode == 1 ? Tokens.light-bg-sidebar : Tokens.dark-bg-sidebar;
    out property <color> bg-toolbar: Tokens.theme-mode == 1 ? Tokens.light-bg-toolbar : Tokens.dark-bg-toolbar;
    out property <color> bg-header: Tokens.theme-mode == 1 ? Tokens.light-bg-header : Tokens.dark-bg-header;
    out property <color> bg-tab-active: Tokens.theme-mode == 1 ? Tokens.light-bg-tab-active : Tokens.dark-bg-tab-active;
    out property <color> bg-tab-inactive: Tokens.theme-mode == 1 ? Tokens.light-bg-tab-inactive : Tokens.dark-bg-tab-inactive;
    out property <color> text-tab-active: Tokens.theme-mode == 1 ? Tokens.light-text-tab-active : Tokens.dark-text-tab-active;
    out property <color> text-tab-inactive: Tokens.theme-mode == 1 ? Tokens.light-text-tab-inactive : Tokens.dark-text-tab-inactive;
    out property <color> border-column: Tokens.theme-mode == 1 ? Tokens.light-border-column : Tokens.dark-border-column;
    out property <color> bg-column-active: Tokens.theme-mode == 1 ? Tokens.light-bg-column-active : Tokens.dark-bg-column-active;
    out property <color> bg-column-inactive: Tokens.theme-mode == 1 ? Tokens.light-bg-column-inactive : Tokens.dark-bg-column-inactive;
    out property <color> bg-inspector: Tokens.theme-mode == 1 ? Tokens.light-bg-inspector : Tokens.dark-bg-inspector;
    out property <color> border-inspector: Tokens.theme-mode == 1 ? Tokens.light-border-inspector : Tokens.dark-border-inspector;
    out property <color> shadow-inspector: Tokens.theme-mode == 1 ? Tokens.light-shadow-inspector : Tokens.dark-shadow-inspector;
    out property <color> bg-status: Tokens.theme-mode == 1 ? Tokens.light-bg-status : Tokens.dark-bg-status;
    out property <color> bg-row-alt: Tokens.theme-mode == 1 ? Tokens.light-bg-row-alt : Tokens.dark-bg-row-alt;
    out property <color> bg-hover: Tokens.theme-mode == 1 ? Tokens.light-bg-hover : Tokens.dark-bg-hover;
    out property <color> bg-selected: Tokens.theme-mode == 1 ? Tokens.light-bg-selected : Tokens.dark-bg-selected;
    out property <color> bg-input: Tokens.theme-mode == 1 ? Tokens.light-bg-input : Tokens.dark-bg-input;
    out property <color> text-primary: Tokens.theme-mode == 1 ? Tokens.light-text-primary : Tokens.dark-text-primary;
    out property <color> text-secondary: Tokens.theme-mode == 1 ? Tokens.light-text-secondary : Tokens.dark-text-secondary;
    out property <color> text-tertiary: Tokens.theme-mode == 1 ? Tokens.light-text-tertiary : Tokens.dark-text-tertiary;
    out property <color> text-on-primary: Tokens.theme-mode == 1 ? Tokens.light-text-on-primary : Tokens.dark-text-on-primary;
    out property <color> border: Tokens.theme-mode == 1 ? Tokens.light-border : Tokens.dark-border;
    out property <color> border-subtle: Tokens.theme-mode == 1 ? Tokens.light-border-subtle : Tokens.dark-border-subtle;
    out property <color> shadow: Tokens.theme-mode == 1 ? Tokens.light-shadow : Tokens.dark-shadow;

    // Brand colors - Luxurious gold accent (works on both themes)
    out property <color> primary: #c9a227;
    out property <color> secondary: #d4b84a;
    out property <color> accent: #e8d48a;
    out property <color> primary-soft: #c9a22730;
    out property <color> primary-hover: #d4b84a;

    // Text colors
    out property <color> text-header: #c9a227;
    out property <color> border-focus: #c9a227;

    // Typography - Premium scale
    out property <length> font-xs: 11px;
    out property <length> font-sm: 13px;
    out property <length> font-md: 14px;
    out property <length> font-lg: 16px;
    out property <length> font-xl: 22px;
    out property <int> font-weight-regular: 400;
    out property <int> font-weight-medium: 500;
    out property <int> font-weight-semibold: 600;
    out property <int> font-weight-bold: 700;
}

export struct TabItem {
    id: string,
    title: string,
    path: string,
}

export struct FileEntry {
    name: string,
    path: string,
    is-dir: bool,
    size: string,
    modified: string,
    icon: string,
    selected: bool,
}

export struct SidebarItem {
    name: string,
    icon: string,
    path: string,
    section: string,
}

component StyledButton {
    in property <string> text: "";
    in property <bool> enabled: true;
    in property <bool> primary: false;
    in property <bool> compact: false;
    callback clicked();

    min-height: 36px;
    max-height: 40px;
    min-width: 36px;
    max-width: 140px;

    TouchArea {
        enabled: root.enabled;
        mouse-cursor: enabled ? pointer : default;
        clicked => { root.clicked() }

        Rectangle {
            border-radius: 8px;
            background: root.primary ? Tokens.primary : (root.enabled ? Tokens.bg-surface : Tokens.bg-row-alt);

            // Subtle shadow effect for depth
            Rectangle {
                x: 1px; y: 1px; width: parent.width - 2px; height: parent.height - 2px;
                border-radius: 7px;
                background: root.primary ? Tokens.secondary : (root.enabled ? Tokens.bg-hover : Tokens.bg-row-alt);
                opacity: root.primary ? 0 : (root.enabled ? 0.5 : 0);
            }

            // Border rectangles (top, left, bottom, right)
            Rectangle {
                x: 0; y: 0; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: 0; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }
            Rectangle {
                x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : Tokens.border-subtle;
            }

            Text {
                text: root.text;
                font-family: "Inter";
                font-size: root.compact ? Tokens.font-xs : Tokens.font-sm;
                font-weight: root.primary ? Tokens.font-weight-semibold : Tokens.font-weight-medium;
                color: root.primary ? Tokens.text-on-primary : (root.enabled ? Tokens.text-secondary : Tokens.text-tertiary);
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component StyledInput {
    in property <string> text: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    in-out property <string> value: root.text;
    callback accepted(string);
    callback edited(string);

    min-height: 36px;
    max-height: 40px;

    Rectangle {
        background: Tokens.bg-input;
        border-radius: 8px;

        // Subtle shadow inside
        Rectangle {
            x: 1px; y: 1px; width: parent.width - 2px; height: parent.height - 2px;
            border-radius: 7px;
            background: Tokens.shadow;
            opacity: 0.5;
        }

        // Border rectangles
        Rectangle {
            x: 0; y: 0; width: parent.width; height: 1px;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: 0; y: 0; width: 1px; height: parent.height;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
            background: Tokens.border-subtle;
        }
        Rectangle {
            x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
            background: Tokens.border-subtle;
        }

        LineEdit {
            text: root.text;
            placeholder-text: root.placeholder;
            enabled: root.enabled;
            horizontal-stretch: 1;
            font-family: "Inter";
            font-size: Tokens.font-sm;
            accepted(text) => { root.accepted(text) }
            edited(text) => { root.edited(text) }
        }
    }
}

component Sidebar {
    in property <[SidebarItem]> items;
    in property <string> active-path;
    callback item-clicked(string);

    min-width: 200px;
    max-width: 260px;
    preferred-width: 220px;

    Rectangle {
        background: Tokens.bg-sidebar;

        // Right shadow effect
        Rectangle {
            x: parent.width - 8px;
            y: 0;
            width: 8px;
            height: parent.height;
            background: Tokens.shadow;
            opacity: 0.6;
        }

        // Right shadow layer 2
        Rectangle {
            x: parent.width - 4px;
            y: 0;
            width: 4px;
            height: parent.height;
            background: Tokens.shadow;
            opacity: 0.4;
        }

        VerticalBox {
            padding: 16px;
            spacing: 8px;

            // Favorites section header
            Text {
                text: "FAVORITES";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: Tokens.font-weight-semibold;
                color: Tokens.text-tertiary;
                letter-spacing: 1px;
            }

            for item in root.items : TouchArea {
                visible: item.section == "favorites";
                height: 44px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 12px;

                    // Active indicator
                    Rectangle {
                        x: 0; y: 8px; width: 3px; height: 28px;
                        background: item.path == root.active-path ? Tokens.primary : transparent;
                        border-radius: 2px;
                    }

                    HorizontalBox {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 12px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-lg;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: item.path == root.active-path ? Tokens.font-weight-medium : Tokens.font-weight-regular;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle { min-height: 24px; max-height: 24px; }

            // Devices section header
            Text {
                text: "DEVICES";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: Tokens.font-weight-semibold;
                color: Tokens.text-tertiary;
                letter-spacing: 1px;
            }

            for item in root.items : TouchArea {
                visible: item.section == "devices";
                height: 44px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 12px;

                    // Active indicator
                    Rectangle {
                        x: 0; y: 8px; width: 3px; height: 28px;
                        background: item.path == root.active-path ? Tokens.primary : transparent;
                        border-radius: 2px;
                    }

                    HorizontalBox {
                        padding-left: 12px;
                        padding-right: 12px;
                        padding-top: 12px;
                        padding-bottom: 12px;
                        spacing: 12px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-lg;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: item.path == root.active-path ? Tokens.font-weight-medium : Tokens.font-weight-regular;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component Toolbar {
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> search-text;

    callback go-back();
    callback go-forward();
    callback go-up();
    callback tab-clicked(int);
    callback tab-closed(int);
    callback new-tab-clicked();

    callback path-entered(string);
    callback search-changed(string);
    callback settings-clicked();
    callback shortcuts-clicked();

    min-height: 52px;
    max-height: 60px;
    preferred-height: 56px;

    Rectangle {
        background: Tokens.bg-toolbar;

        // Bottom shadow layers
        Rectangle {
            y: parent.height - 6px;
            height: 6px;
            width: 100%;
            background: Tokens.shadow;
            opacity: 0.5;
        }
        Rectangle {
            y: parent.height - 3px;
            height: 3px;
            width: 100%;
            background: Tokens.shadow;
            opacity: 0.3;
        }

        // Border
        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            width: 100%;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding: 14px;
            spacing: 12px;

            StyledButton {
                text: "←";
                compact: true;
                enabled: root.can-go-back;
                clicked => { root.go-back() }
            }
            StyledButton {
                text: "→";
                compact: true;
                enabled: root.can-go-forward;
                clicked => { root.go-forward() }
            }
            StyledButton {
                text: "↑";
                compact: true;
                clicked => { root.go-up() }
            }

            Rectangle { width: 1px; background: Tokens.border-subtle; }

            StyledInput {
                text: root.current-path;
                placeholder: "Path...";
                accepted(text) => { root.path-entered(text) }
                horizontal-stretch: 1;
            }

            StyledInput {
                text: root.search-text;
                placeholder: "Search files...";
                edited(text) => { root.search-changed(text) }
                min-width: 180px;
                max-width: 240px;
            }

            // Spacer
            Rectangle { horizontal-stretch: 1; }

            StyledButton {
                text: "?";
                compact: true;
                clicked => { root.shortcuts-clicked() }
            }

            StyledButton {
                text: "⚙";
                compact: true;
                clicked => { root.settings-clicked() }
            }
        }
    }
}

component FileList {
    in property <[FileEntry]> files;
    in property <[int]> selected-indices: [];

    // Sort and column visibility properties from MainWindow
    in property <string> sort-by: "name";
    in property <bool> show-column-name: true;
    in property <bool> show-column-size: true;
    in property <bool> show-column-modified: true;
    in property <bool> show-column-created: true;
    in property <bool> show-column-type: false;
    in-out property <length> sidebar-width: 220px;
    in-out property <bool> sidebar-collapsed: false;


    callback file-selected(int, bool, bool);  // index, ctrl-pressed, shift-pressed
    callback file-activated(int);
    callback sort-requested(string);
    callback sort-menu-clicked();
    callback column-visibility-changed(string, bool);

    VerticalBox {
        padding: 0;
        spacing: 0;

        Rectangle {
            min-height: 44px;
            max-height: 52px;
            background: Tokens.bg-header;

            // Bottom shadow
            Rectangle {
                y: parent.height - 4px;
                height: 4px;
                width: 100%;
                background: Tokens.shadow;
                opacity: 0.3;
            }

            // Border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: 100%;
                background: Tokens.border-subtle;
            }

            HorizontalBox {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 12px;

                // Menu button for sort/columns
                TouchArea {
                    min-width: 24px;
                    max-width: 24px;
                    min-height: 24px;
                    max-height: 24px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-menu-clicked() }

                    Rectangle {
                        background: transparent;
                        border-radius: 4px;

                        Text {
                            text: "☰";
                            font-size: Tokens.font-sm;
                            color: Tokens.text-tertiary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // Spacer between menu and columns
                Rectangle { width: 4px; }

                // Name column
                if (root.show-column-name) : TouchArea {
                    horizontal-stretch: 3;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("name") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        Text {
                            text: "Name";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: Tokens.font-weight-semibold;
                            color: root.sort-by == "name" ? Tokens.primary : Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                            vertical-alignment: center;
                        }
                    }
                }

                // Size column
                if (root.show-column-size) : TouchArea {
                    horizontal-stretch: 0;
                    min-width: 90px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("size") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        Text {
                            text: "Size";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: Tokens.font-weight-semibold;
                            color: root.sort-by == "size" ? Tokens.primary : Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }
                }

                // Modified column
                if (root.show-column-modified) : TouchArea {
                    horizontal-stretch: 0;
                    min-width: 140px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("modified") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        Text {
                            text: "Modified";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: Tokens.font-weight-semibold;
                            color: root.sort-by == "modified" ? Tokens.primary : Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }
                }

                // Created column
                if (root.show-column-created) : TouchArea {
                    horizontal-stretch: 0;
                    min-width: 140px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("created") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        Text {
                            text: "Created";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: Tokens.font-weight-semibold;
                            color: root.sort-by == "created" ? Tokens.primary : Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }
                }

                // Type column
                if (root.show-column-type) : TouchArea {
                    horizontal-stretch: 0;
                    min-width: 80px;
                    mouse-cursor: pointer;
                    clicked => { root.sort-requested("type") }
                    Rectangle {
                        background: transparent;
                        border-radius: 6px;
                        Text {
                            text: "Type";
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            font-weight: Tokens.font-weight-semibold;
                            color: root.sort-by == "type" ? Tokens.primary : Tokens.text-tertiary;
                            letter-spacing: 0.5px;
                            horizontal-alignment: right;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            for entry[index] in root.files : TouchArea {
                min-height: 40px;
                max-height: 48px;
                mouse-cursor: pointer;
                clicked => { 
                    root.file-selected(index, false, false) 
                }

                // Selection background with subtle alternating row colors
                Rectangle {
                    width: 100%;
                    height: 100%;
                    background: entry.selected ? Tokens.bg-selected : (mod(index, 2) == 0 ? Tokens.bg-window : Tokens.bg-row-alt);
                    border-radius: 6px;
                }

                // Hover effect
                Rectangle {
                    width: 100%;
                    height: 100%;
                    background: Tokens.bg-hover;
                    border-radius: 6px;
                    opacity: 0;
                }

                HorizontalBox {
                    padding-left: 20px;
                    padding-right: 20px;
                    spacing: 16px;

                    HorizontalBox {
                        horizontal-stretch: 3;
                        spacing: 12px;

                        // Background circle for icon visibility
                        Rectangle {
                            min-width: 28px;
                            max-width: 28px;
                            min-height: 28px;
                            max-height: 28px;
                            background: Tokens.bg-hover;
                            border-radius: 14px;

                            Text {
                                text: entry.icon;
                                font-size: Tokens.font-md;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: entry.name;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            color: entry.selected ? Tokens.text-primary : Tokens.text-primary;
                            font-weight: entry.selected ? Tokens.font-weight-medium : Tokens.font-weight-regular;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        min-width: 90px;
                        horizontal-stretch: 0;
                        text: entry.size;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: entry.selected ? Tokens.text-secondary : Tokens.text-secondary;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }

                    Text {
                        min-width: 140px;
                        horizontal-stretch: 0;
                        text: entry.modified;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: entry.selected ? Tokens.text-secondary : Tokens.text-secondary;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }
                }
            }
        }
    }
}

component StatusBar {
    in property <int> item-count;
    in property <string> status-message;

    min-height: 36px;
    max-height: 44px;
    preferred-height: 40px;

    Rectangle {
        background: Tokens.bg-status;

        // Top shadow layers
        Rectangle {
            y: 0;
            height: 4px;
            width: 100%;
            background: Tokens.shadow;
            opacity: 0.4;
        }
        Rectangle {
            y: 3px;
            height: 2px;
            width: 100%;
            background: Tokens.shadow;
            opacity: 0.2;
        }

        // Border
        Rectangle {
            y: 5px;
            height: 1px;
            width: 100%;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding-left: 24px;
            padding-right: 24px;

            Text {
                text: "\{root.item-count} items";
                font-family: "Inter";
                font-size: Tokens.font-xs;
                font-weight: Tokens.font-weight-medium;
                color: Tokens.text-secondary;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: root.status-message;
                font-family: "Inter";
                font-size: Tokens.font-xs;
                color: Tokens.text-tertiary;
                horizontal-alignment: right;
            }
        }
    }
}

component DetailsPanel {
    in property <bool> show: true;
    in property <length> panel-width: 280px;
    in property <string> file-name: "";
    in property <string> file-path: "";
    in property <string> file-size: "";
    in property <string> file-modified: "";
    in property <string> file-created: "";
    in property <string> file-mime: "";
    in property <bool> file-is-dir: false;
    callback toggle();

    Rectangle {
        width: root.panel-width;
        background: Tokens.bg-surface;

        // Left shadow effect
        Rectangle {
            x: 0;
            y: 0;
            width: 8px;
            height: parent.height;
            background: Tokens.shadow;
            opacity: 0.6;
        }

        // Left shadow layer 2
        Rectangle {
            x: 4px;
            y: 0;
            width: 4px;
            height: parent.height;
            background: Tokens.shadow;
            opacity: 0.4;
        }

        // Border
        Rectangle {
            x: 8px;
            y: 0;
            width: 1px;
            height: parent.height;
            background: Tokens.border-subtle;
        }

        VerticalBox {
            padding: 16px;
            spacing: 16px;

            // Header with toggle
            HorizontalBox {
                spacing: 8px;

                Text {
                    text: "DETAILS";
                    font-family: "Inter";
                    font-size: Tokens.font-xs;
                    font-weight: Tokens.font-weight-semibold;
                    color: Tokens.text-tertiary;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                TouchArea {
                    min-width: 28px;
                    max-width: 28px;
                    min-height: 28px;
                    max-height: 28px;
                    mouse-cursor: pointer;
                    clicked => { root.toggle() }

                    Rectangle {
                        background: Tokens.bg-hover;
                        border-radius: 6px;

                        Text {
                            text: "×";
                            font-size: Tokens.font-lg;
                            color: Tokens.text-secondary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Divider
            Rectangle {
                height: 1px;
                background: Tokens.border-subtle;
            }

            // File icon with background circle
            if (root.file-name != "") : VerticalBox {
                alignment: center;
                min-height: 80px;

                // Background circle for icon
                Rectangle {
                    width: 64px;
                    height: 64px;
                    background: Tokens.bg-hover;
                    border-radius: 32px;

                    Text {
                        text: root.file-is-dir ? "📁" : "📄";
                        font-size: 32px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // File name
            if (root.file-name != "") : Text {
                text: root.file-name;
                font-family: "Inter";
                font-size: Tokens.font-md;
                font-weight: Tokens.font-weight-medium;
                color: Tokens.text-primary;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            // PDF preview placeholder (when PDF selected)
            if (root.file-mime == "application/pdf" && root.file-name != "") : Rectangle {
                min-height: 120px;
                max-height: 140px;
                background: Tokens.bg-row-alt;
                border-radius: 8px;

                VerticalBox {
                    spacing: 8px;

                    Text {
                        text: "PDF Preview";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                        horizontal-alignment: center;
                    }

                    // Placeholder area
                    Rectangle {
                        min-height: 80px;
                        background: Tokens.bg-surface;
                        border-radius: 4px;

                        Text {
                            text: "[PDF viewer]\n\nComing soon...";
                            font-family: "Inter";
                            font-size: Tokens.font-xs;
                            color: Tokens.text-tertiary;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // File details
            if (root.file-name != "" && root.file-path != "") : VerticalBox {
                spacing: 12px;

                // Path
                VerticalBox {
                    spacing: 4px;

                    Text {
                        text: "Path";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                    }

                    Text {
                        text: root.file-path;
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        color: Tokens.text-secondary;
                        wrap: word-wrap;
                    }
                }

                // Size
                if (root.file-size != "") : VerticalBox {
                    spacing: 4px;

                    Text {
                        text: "Size";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                    }

                    Text {
                        text: root.file-size;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: Tokens.text-primary;
                    }
                }

                // Modified
                if (root.file-modified != "") : VerticalBox {
                    spacing: 4px;

                    Text {
                        text: "Modified";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                    }

                    Text {
                        text: root.file-modified;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: Tokens.text-primary;
                    }
                }

                // Created
                if (root.file-created != "") : VerticalBox {
                    spacing: 4px;

                    Text {
                        text: "Created";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                    }

                    Text {
                        text: root.file-created;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: Tokens.text-primary;
                    }
                }

                // Type/MIME
                if (root.file-mime != "") : VerticalBox {
                    spacing: 4px;

                    Text {
                        text: "Type";
                        font-family: "Inter";
                        font-size: Tokens.font-xs;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-tertiary;
                    }

                    Text {
                        text: root.file-mime;
                        font-family: "Inter";
                        font-size: Tokens.font-sm;
                        color: Tokens.text-primary;
                    }
                }
            }

            // Empty state
            if (root.file-name == "") : VerticalBox {
                spacing: 12px;
                padding-top: 40px;

                Text {
                    text: "Select a file";
                    font-family: "Inter";
                    font-size: Tokens.font-sm;
                    color: Tokens.text-tertiary;
                    horizontal-alignment: center;
                }

                Text {
                    text: "to view details";
                    font-family: "Inter";
                    font-size: Tokens.font-xs;
                    color: Tokens.text-tertiary;
                    horizontal-alignment: center;
                }
            }
        }
    }
}

export component TabBar inherits Rectangle {
    in property <[TabItem]> tabs;
    in property <int> active-index;
    callback tab-clicked(int);
    callback tab-closed(int);
    callback new-tab();
    height: 32px;
    background: Tokens.bg-toolbar;
    HorizontalBox {
        padding: 0;
        spacing: 4px;
        for tab[i] in tabs : Rectangle {
            width: 150px;
            background: i == active-index ? Tokens.bg-tab-active : Tokens.bg-tab-inactive;
            border-radius: 4px;
            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                Text {
                    text: tab.title;
                    color: i == active-index ? Tokens.text-tab-active : Tokens.text-tab-inactive;
                    font-size: Tokens.font-sm;
                    font-weight: i == active-index ? Tokens.font-weight-medium : Tokens.font-weight-regular;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    overflow: elide;
                }
                Rectangle {
                    width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    background: close-ta.has-hover ? Tokens.bg-hover : transparent;
                    Text {
                        text: "×";
                        color: i == active-index ? Tokens.text-tab-active : Tokens.text-tab-inactive;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-alignment: center;
                    }
                    close-ta := TouchArea {
                        clicked => { root.tab-closed(i); }
                    }
                }
            }
            TouchArea {
                width: parent.width - 24px;
                x: 0;
                clicked => { root.tab-clicked(i); }
            }
        }
        Rectangle {
            width: 32px;
            height: 32px;
            background: new-ta.has-hover ? Tokens.bg-hover : transparent;
            Text {
                text: "+";
                color: Tokens.text-secondary;
                font-size: 18px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
            new-ta := TouchArea {
                clicked => { root.new-tab(); }
            }
        }
        Rectangle {
            horizontal-stretch: 1;
        }
    }
}

export component MainWindow inherits Window {
    title: "felix";
    min-width: 640px;
    min-height: 420px;
    preferred-width: 960px;
    preferred-height: 640px;
    background: Tokens.bg-window;

    in property <[TabItem]> tabs: [{id: "1", title: "Home", path: "/home"}];
    in property <int> active-tab-index: 0;
    in property <string> current-path: "/home";
    in property <[FileEntry]> files: [];
    in property <[SidebarItem]> sidebar-items: [];
    in property <string> sidebar-active-path: "";
    in property <[int]> selected-indices: [];
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    in property <string> search-text: "";
    in property <string> status-message: "";

    // Details panel
    in property <bool> show-details-panel: false;
    in property <length> details-panel-width: 280px;
    in property <string> selected-file-path: "";
    in property <string> selected-file-name: "";
    in property <string> selected-file-size: "";
    in property <string> selected-file-modified: "";
    in property <string> selected-file-created: "";
    in property <string> selected-file-mime: "";
    in property <bool> selected-file-is-dir: false;

    // Sort and column visibility
    in property <string> sort-by: "name";
    in property <bool> show-column-name: true;
    in property <bool> show-column-size: true;
    in property <bool> show-column-modified: true;
    in property <bool> show-column-created: true;
    in property <bool> show-column-type: false;
    in-out property <length> sidebar-width: 220px;
    in-out property <bool> sidebar-collapsed: false;


    callback go-back();
    callback go-forward();
    callback go-up();
    callback tab-clicked(int);
    callback tab-closed(int);
    callback new-tab-clicked();

    callback path-entered(string);
    callback search-changed(string);
    callback sidebar-item-clicked(string);
    callback file-selected(int, bool, bool);
    callback file-activated(int);
    callback sort-requested(string);
    callback sort-menu-clicked();
    callback column-visibility-changed(string, bool);
    callback details-panel-toggle();
    callback settings-clicked();
    callback shortcuts-clicked();

    VerticalBox {
        TabBar {
            tabs: root.tabs;
            active-index: root.active-tab-index;
            tab-clicked(i) => { root.tab-clicked(i) }
            tab-closed(i) => { root.tab-closed(i) }
            new-tab => { root.new-tab-clicked() }
        }
        spacing: 0;

        Toolbar {
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            search-text: root.search-text;
            go-back => { root.go-back() }
            go-forward => { root.go-forward() }
            go-up => { root.go-up() }
            path-entered(p) => { root.path-entered(p) }
            search-changed(s) => { root.search-changed(s) }
            settings-clicked => { root.settings-clicked() }
            shortcuts-clicked => { root.shortcuts-clicked() }
        }

        HorizontalBox {
            spacing: 0;

            Sidebar {
                items: root.sidebar-items;
                active-path: root.sidebar-active-path;
                item-clicked(p) => { root.sidebar-item-clicked(p) }
            }

            Rectangle {
                width: 1px;
                background: Tokens.border;
            }

            FileList {
                files: root.files;
                selected-indices: root.selected-indices;
                sort-by: root.sort-by;
                show-column-name: root.show-column-name;
                show-column-size: root.show-column-size;
                show-column-modified: root.show-column-modified;
                show-column-created: root.show-column-created;
                show-column-type: root.show-column-type;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                file-selected(i, ctrl, shift) => { root.file-selected(i, ctrl, shift) }
                file-activated(i) => { root.file-activated(i) }
                sort-requested(col) => { root.sort-requested(col) }
                sort-menu-clicked => { root.sort-menu-clicked() }
                column-visibility-changed(col, vis) => { root.column-visibility-changed(col, vis) }
            }

            // Vertical separator between FileList and DetailsPanel
            if (root.show-details-panel) : Rectangle {
                width: 1px;
                background: Tokens.border;
            }

            // Details panel on the right
            if (root.show-details-panel) : DetailsPanel {
                show: root.show-details-panel;
                panel-width: root.details-panel-width;
                file-name: root.selected-file-name;
                file-path: root.selected-file-path;
                file-size: root.selected-file-size;
                file-modified: root.selected-file-modified;
                file-created: root.selected-file-created;
                file-mime: root.selected-file-mime;
                file-is-dir: root.selected-file-is-dir;
                toggle => { root.details-panel-toggle() }
            }
        }

        StatusBar {
            item-count: root.files.length;
            status-message: root.status-message;
        }
    }
}

export component SetupDialog inherits Dialog {
    title: "felix — First Launch";
    min-width: 400px;
    min-height: 320px;
    background: Tokens.bg-window;

    in-out property <bool> enable-markdown: true;
    in-out property <bool> enable-pdf: true;
    in-out property <bool> enable-docx: false;
    in-out property <bool> enable-pptx: false;

    callback setup-complete();

    VerticalBox {
        padding: 32px;
        spacing: 28px;

        Text {
            text: "Welcome to felix";
            font-family: "Inter";
            font-size: Tokens.font-xl;
            font-weight: Tokens.font-weight-bold;
            color: Tokens.text-primary;
        }

        Text {
            text: "Choose tools to enable:";
            font-family: "Inter";
            font-size: Tokens.font-md;
            color: Tokens.text-secondary;
        }

        VerticalBox {
            spacing: 16px;

            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-markdown; toggled => { root.enable-markdown = self.checked } }
                Text { text: "Markdown"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-pdf; toggled => { root.enable-pdf = self.checked } }
                Text { text: "PDF"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-docx; toggled => { root.enable-docx = self.checked } }
                Text { text: "DOCX"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 14px;
                CheckBox { checked: root.enable-pptx; toggled => { root.enable-pptx = self.checked } }
                Text { text: "PPTX"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
        }

        Rectangle { vertical-stretch: 1; }

        StyledButton {
            text: "Get Started";
            primary: true;
            clicked => { root.setup-complete() }
        }
    }
}

export component SettingsDialog inherits Dialog {
    title: "felix — Settings";
    min-width: 560px;
    min-height: 580px;
    background: Tokens.bg-window;

    // General
    in-out property <bool> show-hidden: false;
    in-out property <bool> confirm-delete: true;
    in-out property <int> page-size: 100;

    // Theme
    in-out property <int> theme-mode: 0; // 0=System, 1=Light, 2=Dark
    in-out property <string> accent-color: "#c9a227";

    // Tools
    in-out property <bool> markdown-preview: true;
    in-out property <bool> pdf-preview: true;
    in-out property <bool> docx-preview: false;
    in-out property <bool> pptx-preview: false;

    // Sidebar
    in-out property <bool> show-devices: true;
    in-out property <bool> show-bookmarks: true;

    // Viewers
    in-out property <string> image-viewer: "imv";
    in-out property <string> video-viewer: "mpv";
    in-out property <string> pdf-viewer: "zathura";

    callback save-config();
    callback close-dialog();

    VerticalBox {
        padding: 32px;
        spacing: 20px;

        Text {
            text: "Settings";
            font-family: "Inter";
            font-size: Tokens.font-xl;
            font-weight: Tokens.font-weight-bold;
            color: Tokens.text-primary;
        }

        ScrollView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            VerticalBox {
                padding: 4px;
                spacing: 28px;

                // ─── General ──────────────────────────────────────
                VerticalBox {
                    spacing: 16px;

                    // Section header with gold underline
                    Rectangle {
                        height: 2px;
                        background: Tokens.primary;
                        max-width: 60px;
                    }

                    Text {
                        text: "General";
                        font-family: "Inter";
                        font-size: Tokens.font-lg;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-primary;
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.show-hidden; toggled => { root.show-hidden = self.checked } }
                        Text { text: "Show hidden files"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.confirm-delete; toggled => { root.confirm-delete = self.checked } }
                        Text { text: "Confirm before deleting"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "Page size:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        SpinBox {
                            value: root.page-size;
                            minimum: 10;
                            maximum: 1000;
                            step-size: 10;
                            edited(value) => { root.page-size = value }
                        }
                    }
                }

                // ─── Theme ────────────────────────────────────────
                VerticalBox {
                    spacing: 16px;

                    // Section header with gold underline
                    Rectangle {
                        height: 2px;
                        background: Tokens.primary;
                        max-width: 60px;
                    }

                    Text {
                        text: "Theme";
                        font-family: "Inter";
                        font-size: Tokens.font-lg;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-primary;
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "Theme:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        ComboBox {
                            model: ["System", "Light", "Dark"];
                            current-index <=> root.theme-mode;
                        }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "Accent color:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.accent-color;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.accent-color = text }
                        }
                    }
                }

                // ─── Document Tools ───────────────────────────────
                VerticalBox {
                    spacing: 16px;

                    // Section header with gold underline
                    Rectangle {
                        height: 2px;
                        background: Tokens.primary;
                        max-width: 60px;
                    }

                    Text {
                        text: "Document Tools";
                        font-family: "Inter";
                        font-size: Tokens.font-lg;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-primary;
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.markdown-preview; toggled => { root.markdown-preview = self.checked } }
                        Text { text: "Markdown preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.pdf-preview; toggled => { root.pdf-preview = self.checked } }
                        Text { text: "PDF preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.docx-preview; toggled => { root.docx-preview = self.checked } }
                        Text { text: "DOCX preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.pptx-preview; toggled => { root.pptx-preview = self.checked } }
                        Text { text: "PPTX preview"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }
                }

                // ─── Sidebar ──────────────────────────────────────
                VerticalBox {
                    spacing: 16px;

                    // Section header with gold underline
                    Rectangle {
                        height: 2px;
                        background: Tokens.primary;
                        max-width: 60px;
                    }

                    Text {
                        text: "Sidebar";
                        font-family: "Inter";
                        font-size: Tokens.font-lg;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-primary;
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.show-devices; toggled => { root.show-devices = self.checked } }
                        Text { text: "Show devices"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        CheckBox { checked: root.show-bookmarks; toggled => { root.show-bookmarks = self.checked } }
                        Text { text: "Show bookmarks"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
                    }
                }

                // ─── External Viewers ─────────────────────────────
                VerticalBox {
                    spacing: 16px;

                    // Section header with gold underline
                    Rectangle {
                        height: 2px;
                        background: Tokens.primary;
                        max-width: 60px;
                    }

                    Text {
                        text: "External Viewers";
                        font-family: "Inter";
                        font-size: Tokens.font-lg;
                        font-weight: Tokens.font-weight-semibold;
                        color: Tokens.text-primary;
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "Images:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.image-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.image-viewer = text }
                        }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "Video:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.video-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.video-viewer = text }
                        }
                    }

                    HorizontalBox {
                        spacing: 14px;
                        Text { text: "PDF:"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-secondary; min-width: 100px; }
                        LineEdit {
                            text: root.pdf-viewer;
                            font-family: "Inter";
                            font-size: Tokens.font-sm;
                            edited(text) => { root.pdf-viewer = text }
                        }
                    }
                }
            }
        }

        HorizontalBox {
            spacing: 14px;

            StyledButton {
                text: "Cancel";
                clicked => { root.close-dialog() }
            }

            Rectangle { horizontal-stretch: 1; }

            StyledButton {
                text: "Save";
                primary: true;
                clicked => { root.save-config() }
            }
        }
    }
}

export component ShortcutsDialog inherits Dialog {
    title: "felix — Keyboard Shortcuts";
    min-width: 440px;
    min-height: 520px;
    background: Tokens.bg-window;

    callback close();

    VerticalBox {
        padding: 32px;
        spacing: 24px;

        Text {
            text: "Keyboard Shortcuts";
            font-family: "Inter";
            font-size: Tokens.font-xl;
            font-weight: Tokens.font-weight-bold;
            color: Tokens.text-primary;
        }

        // Navigation
        Text {
            text: "Navigation";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: Tokens.font-weight-semibold;
            color: Tokens.text-primary;
        }

        VerticalBox {
            spacing: 8px;
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Enter"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; vertical-alignment: center; } }
                Text { text: "Open file or folder"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Backspace"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; vertical-alignment: center; } }
                Text { text: "Go to parent directory"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "h"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; vertical-alignment: center; } }
                Text { text: "Go back in history"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "l"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Go forward in history"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "j"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Select next file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "k"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Select previous file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
        }

        // Selection
        Text {
            text: "Selection";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: Tokens.font-weight-semibold;
            color: Tokens.text-primary;
        }

        VerticalBox {
            spacing: 8px;
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Click"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Select single file"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+Click"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Toggle selection"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Shift+Click"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Select range"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+Shift+Click"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Extend range"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+A"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Select all"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
        }

        // File Operations
        Text {
            text: "File Operations";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: Tokens.font-weight-semibold;
            color: Tokens.text-primary;
        }

        VerticalBox {
            spacing: 8px;
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Delete"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Delete selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "F2"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Rename selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+C"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Copy selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+X"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Cut selected"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+V"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Paste"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
        }

        // Other
        Text {
            text: "Other";
            font-family: "Inter";
            font-size: Tokens.font-md;
            font-weight: Tokens.font-weight-semibold;
            color: Tokens.text-primary;
        }

        VerticalBox {
            spacing: 8px;
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+F"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Focus search"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "Ctrl+,"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Open settings"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "?"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Show shortcuts"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
            HorizontalBox { 
                Rectangle { min-width: 100px; max-width: 100px; background: Tokens.bg-surface; border-radius: 4px; Text { text: "F5"; font-family: "Inter"; font-size: Tokens.font-xs; color: Tokens.text-secondary; horizontal-alignment: center; } }
                Text { text: "Refresh"; font-family: "Inter"; font-size: Tokens.font-sm; color: Tokens.text-primary; horizontal-alignment: left; horizontal-stretch: 1; } 
            }
        }

        Rectangle { vertical-stretch: 1; }

        StyledButton {
            text: "Close";
            primary: true;
            clicked => { root.close() }
        }
    }
}
