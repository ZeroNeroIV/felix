import { Button, LineEdit, HorizontalBox, VerticalBox, CheckBox, ListView } from "std-widgets.slint";

global Tokens {
    out property <color> bg-window: #0d1117;
    out property <color> bg-surface: #161b22;
    out property <color> bg-sidebar: #161b22;
    out property <color> bg-toolbar: #0d1117;
    out property <color> bg-header: #161b22;
    out property <color> bg-status: #0d1117;
    out property <color> bg-row-alt: #161b22;
    out property <color> bg-hover: #21262d;
    out property <color> bg-selected: #1f6feb;
    out property <color> bg-input: #0d1117;

    out property <color> primary: #58a6ff;
    out property <color> secondary: #79c0ff;
    out property <color> accent: #f78166;
    out property <color> primary-soft: #1f6feb;
    out property <color> primary-hover: #58a6ff;

    out property <color> text-primary: #c9d1d9;
    out property <color> text-secondary: #8b949e;
    out property <color> text-tertiary: #6e7681;
    out property <color> text-on-primary: #ffffff;
    out property <color> text-header: #58a6ff;

    out property <color> border: #30363d;
    out property <color> border-subtle: #21262d;

    out property <length> font-xs: 11px;
    out property <length> font-sm: 12px;
    out property <length> font-md: 13px;
    out property <length> font-lg: 14px;
}

export struct FileEntry {
    name: string,
    path: string,
    is-dir: bool,
    size: string,
    modified: string,
    icon: string,
}

export struct SidebarItem {
    name: string,
    icon: string,
    path: string,
    section: string,
}

component StyledButton {
    in property <string> text: "";
    in property <bool> enabled: true;
    in property <bool> primary: false;
    callback clicked();

    min-height: 28px;
    max-height: 32px;
    min-width: 28px;
    max-width: 120px;

    TouchArea {
        enabled: root.enabled;
        mouse-cursor: enabled ? pointer : default;
        clicked => { root.clicked() }

        Rectangle {
            border-radius: 4px;
            background: root.primary ? Tokens.primary : (root.enabled ? Tokens.bg-surface : Tokens.bg-row-alt);

            Rectangle {
                x: 0; y: 0; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : (root.enabled ? Tokens.border : Tokens.border-subtle);
            }
            Rectangle {
                x: 0; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : (root.enabled ? Tokens.border : Tokens.border-subtle);
            }
            Rectangle {
                x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
                background: root.primary ? Tokens.primary : (root.enabled ? Tokens.border : Tokens.border-subtle);
            }
            Rectangle {
                x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
                background: root.primary ? Tokens.primary : (root.enabled ? Tokens.border : Tokens.border-subtle);
            }

            Text {
                text: root.text;
                font-size: Tokens.font-sm;
                color: root.primary ? Tokens.text-on-primary : (root.enabled ? Tokens.text-primary : Tokens.text-tertiary);
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

component StyledInput {
    in property <string> text: "";
    in property <string> placeholder: "";
    in property <bool> enabled: true;
    in-out property <string> value: root.text;
    callback accepted(string);
    callback edited(string);

    min-height: 28px;
    max-height: 32px;

    Rectangle {
        background: Tokens.bg-input;
        border-radius: 4px;

        Rectangle {
            x: 0; y: 0; width: parent.width; height: 1px;
            background: Tokens.border;
        }
        Rectangle {
            x: 0; y: 0; width: 1px; height: parent.height;
            background: Tokens.border;
        }
        Rectangle {
            x: 0; y: parent.height - 1px; width: parent.width; height: 1px;
            background: Tokens.border;
        }
        Rectangle {
            x: parent.width - 1px; y: 0; width: 1px; height: parent.height;
            background: Tokens.border;
        }

        LineEdit {
            text: root.text;
            placeholder-text: root.placeholder;
            enabled: root.enabled;
            horizontal-stretch: 1;
            font-size: Tokens.font-sm;
            accepted(text) => { root.accepted(text) }
            edited(text) => { root.edited(text) }
        }
    }
}

component Sidebar {
    in property <[SidebarItem]> items;
    in property <string> active-path;
    callback item-clicked(string);

    min-width: 200px;
    max-width: 260px;
    preferred-width: 220px;

    Rectangle {
        background: Tokens.bg-sidebar;

        VerticalBox {
            padding: 12px;
            spacing: 2px;

            Text {
                text: "Favorites";
                font-size: Tokens.font-xs;
                font-weight: 600;
                color: Tokens.text-tertiary;
            }

            for item in root.items : TouchArea {
                visible: item.section == "favorites";
                height: 32px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 4px;

                    HorizontalBox {
                        padding-left: 10px;
                        spacing: 8px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-size: Tokens.font-sm;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            Rectangle { min-height: 16px; max-height: 16px; }

            Text {
                text: "Devices";
                font-size: Tokens.font-xs;
                font-weight: 600;
                color: Tokens.text-tertiary;
            }

            for item in root.items : TouchArea {
                visible: item.section == "devices";
                height: 32px;
                mouse-cursor: pointer;
                clicked => { root.item-clicked(item.path) }

                Rectangle {
                    background: item.path == root.active-path ? Tokens.bg-selected : transparent;
                    border-radius: 4px;

                    HorizontalBox {
                        padding-left: 10px;
                        spacing: 8px;

                        Text {
                            text: item.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: item.name;
                            font-size: Tokens.font-sm;
                            color: item.path == root.active-path ? Tokens.text-primary : Tokens.text-secondary;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

component Toolbar {
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> search-text;

    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);

    min-height: 44px;
    max-height: 48px;
    preferred-height: 46px;

    Rectangle {
        background: Tokens.bg-toolbar;

        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding: 8px;
            spacing: 6px;

            StyledButton {
                text: "◀";
                enabled: root.can-go-back;
                clicked => { root.go-back() }
            }
            StyledButton {
                text: "▶";
                enabled: root.can-go-forward;
                clicked => { root.go-forward() }
            }
            StyledButton {
                text: "▲";
                clicked => { root.go-up() }
            }

            StyledInput {
                text: root.current-path;
                placeholder: "Path...";
                accepted(text) => { root.path-entered(text) }
                horizontal-stretch: 1;
            }

            StyledInput {
                text: root.search-text;
                placeholder: "Search...";
                edited(text) => { root.search-changed(text) }
                min-width: 140px;
                max-width: 200px;
            }
        }
    }
}

component FileList {
    in property <[FileEntry]> files;
    in property <int> selected-index: -1;

    callback file-selected(int);
    callback file-activated(int);
    callback sort-requested(string);

    VerticalBox {
        padding: 0;
        spacing: 0;

        Rectangle {
            min-height: 32px;
            max-height: 36px;
            background: Tokens.bg-header;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                width: 100%;
                background: Tokens.border-subtle;
            }

            HorizontalBox {
                padding-left: 12px;
                spacing: 8px;

                TouchArea {
                    horizontal-stretch: 3;
                    clicked => { root.sort-requested("name") }
                    Text {
                        text: "Name";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                    }
                }

                TouchArea {
                    horizontal-stretch: 0;
                    min-width: 80px;
                    clicked => { root.sort-requested("size") }
                    Text {
                        text: "Size";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                    }
                }

                TouchArea {
                    horizontal-stretch: 0;
                    min-width: 120px;
                    clicked => { root.sort-requested("modified") }
                    Text {
                        text: "Modified";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                    }
                }
            }
        }

        ListView {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            for entry[index] in root.files : TouchArea {
                min-height: 30px;
                max-height: 34px;
                mouse-cursor: pointer;
                clicked => { root.file-selected(index) }
                double-clicked => { root.file-activated(index) }

                Rectangle {
                    width: 100%;
                    height: 100%;
                    background: index == root.selected-index ? Tokens.bg-selected : (mod(index, 2) == 0 ? Tokens.bg-window : Tokens.bg-row-alt);
                }

                HorizontalBox {
                    padding-left: 12px;
                    spacing: 8px;

                    HorizontalBox {
                        horizontal-stretch: 3;
                        spacing: 8px;
                        Text {
                            text: entry.icon;
                            font-size: Tokens.font-md;
                            vertical-alignment: center;
                        }
                        Text {
                            text: entry.name;
                            font-size: Tokens.font-sm;
                            color: Tokens.text-primary;
                            overflow: elide;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        min-width: 80px;
                        horizontal-stretch: 0;
                        text: entry.size;
                        font-size: Tokens.font-sm;
                        color: Tokens.text-secondary;
                        vertical-alignment: center;
                    }

                    Text {
                        min-width: 120px;
                        horizontal-stretch: 0;
                        text: entry.modified;
                        font-size: Tokens.font-sm;
                        color: Tokens.text-secondary;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

component StatusBar {
    in property <int> item-count;
    in property <string> status-message;

    min-height: 26px;
    max-height: 30px;
    preferred-height: 28px;

    Rectangle {
        background: Tokens.bg-status;

        Rectangle {
            y: 0;
            height: 1px;
            width: 100%;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding-left: 12px;
            padding-right: 12px;

            Text {
                text: "\{root.item-count} items";
                font-size: Tokens.font-xs;
                color: Tokens.text-secondary;
            }

            Text {
                text: root.status-message;
                font-size: Tokens.font-xs;
                color: Tokens.text-tertiary;
                horizontal-alignment: right;
            }
        }
    }
}

export component MainWindow inherits Window {
    title: "felix";
    min-width: 640px;
    min-height: 420px;
    preferred-width: 960px;
    preferred-height: 640px;
    background: Tokens.bg-window;

    in property <string> current-path: "/home";
    in property <[FileEntry]> files: [];
    in property <[SidebarItem]> sidebar-items: [];
    in property <string> sidebar-active-path: "";
    in property <int> selected-index: -1;
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    in property <string> search-text: "";
    in property <string> status-message: "";

    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);
    callback sidebar-item-clicked(string);
    callback file-selected(int);
    callback file-activated(int);
    callback sort-requested(string);

    VerticalBox {
        spacing: 0;

        Toolbar {
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            search-text: root.search-text;
            go-back => { root.go-back() }
            go-forward => { root.go-forward() }
            go-up => { root.go-up() }
            path-entered(p) => { root.path-entered(p) }
            search-changed(s) => { root.search-changed(s) }
        }

        HorizontalBox {
            spacing: 0;

            Sidebar {
                items: root.sidebar-items;
                active-path: root.sidebar-active-path;
                item-clicked(p) => { root.sidebar-item-clicked(p) }
            }

            Rectangle {
                width: 1px;
                background: Tokens.border;
            }

            FileList {
                files: root.files;
                selected-index: root.selected-index;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                file-selected(i) => { root.file-selected(i) }
                file-activated(i) => { root.file-activated(i) }
                sort-requested(col) => { root.sort-requested(col) }
            }
        }

        StatusBar {
            item-count: root.files.length;
            status-message: root.status-message;
        }
    }
}

export component SetupDialog inherits Dialog {
    title: "felix — First Launch";
    min-width: 380px;
    min-height: 280px;
    background: Tokens.bg-window;

    in-out property <bool> enable-markdown: true;
    in-out property <bool> enable-pdf: true;
    in-out property <bool> enable-docx: false;
    in-out property <bool> enable-pptx: false;

    callback setup-complete();

    VerticalBox {
        padding: 24px;
        spacing: 20px;

        Text {
            text: "Welcome to felix";
            font-size: 18px;
            font-weight: 600;
            color: Tokens.text-primary;
        }

        Text {
            text: "Choose tools to enable:";
            font-size: Tokens.font-md;
            color: Tokens.text-secondary;
        }

        VerticalBox {
            spacing: 12px;

            HorizontalBox {
                spacing: 12px;
                CheckBox { checked: root.enable-markdown; toggled => { root.enable-markdown = self.checked } }
                Text { text: "Markdown"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 12px;
                CheckBox { checked: root.enable-pdf; toggled => { root.enable-pdf = self.checked } }
                Text { text: "PDF"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 12px;
                CheckBox { checked: root.enable-docx; toggled => { root.enable-docx = self.checked } }
                Text { text: "DOCX"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
            HorizontalBox {
                spacing: 12px;
                CheckBox { checked: root.enable-pptx; toggled => { root.enable-pptx = self.checked } }
                Text { text: "PPTX"; font-size: Tokens.font-sm; color: Tokens.text-primary; }
            }
        }

        Rectangle { vertical-stretch: 1; }

        StyledButton {
            text: "Get Started";
            primary: true;
            clicked => { root.setup-complete() }
        }
    }
}
