import { Button, LineEdit, HorizontalBox, VerticalBox, CheckBox } from "std-widgets.slint";

// ─── Design Tokens ──────────────────────────────────────────────────────────

global Tokens {
    // Surfaces — purple palette: #a393bf #9882ac #73648a #453750 #0c0910
    out property <color> bg-window: #0c0910;
    out property <color> bg-sidebar: #14101a;
    out property <color> bg-toolbar: #1a1520;
    out property <color> bg-header: #1e1826;
    out property <color> bg-status: #1e1826;
    out property <color> bg-row-alt: #16111d;
    out property <color> bg-hover: #453750;
    out property <color> bg-selected: #453750;

    // Accent — purple spectrum
    out property <color> accent: #9882ac;
    out property <color> accent-soft: #45375066;
    out property <color> accent-hover: #a393bf;

    // Text
    out property <color> text-primary: #cdc0df;
    out property <color> text-secondary: #8a7898;
    out property <color> text-tertiary: #6a5a78;
    out property <color> text-on-accent: #0c0910;
    out property <color> text-header: #9882ac;

    // Borders
    out property <color> border: #453750;
    out property <color> border-subtle: #2a2233;

    // Fonts
    out property <length> font-xs: 11px;
    out property <length> font-sm: 12px;
    out property <length> font-md: 13px;
    out property <length> font-lg: 14px;
}

// ─── Data Models ────────────────────────────────────────────────────────────

export struct FileEntry {
    name: string,
    path: string,
    is-dir: bool,
    size: string,
    modified: string,
    icon: string,
}

export struct SidebarItem {
    name: string,
    icon: string,
    path: string,
    section: string,
}

// ─── Sidebar ────────────────────────────────────────────────────────────────

component Sidebar {
    in property <[SidebarItem]> items;
    in property <string> active-path;
    callback item-clicked(string);

    min-width: 180px;
    preferred-width: 200px;

    Rectangle {
        background: Tokens.bg-sidebar;

        VerticalBox {
            padding: 10px;
            spacing: 2px;

            // Favorites header
            Text {
                text: "Favorites";
                font-size: Tokens.font-xs;
                font-weight: 700;
                color: Tokens.text-secondary;
                letter-spacing: 0.5px;
                x: 10px;
            }

            // Favorites items
            for item in root.items : Rectangle {
                height: 30px;
                border-radius: 6px;
                background: item.path == root.active-path ? Tokens.bg-hover : transparent;

                HorizontalBox {
                    padding-left: 10px;
                    spacing: 8px;

                    Text {
                        text: item.icon;
                        font-size: Tokens.font-lg;
                        vertical-alignment: center;
                    }
                    Text {
                        text: item.name;
                        font-size: Tokens.font-md;
                        font-weight: item.path == root.active-path ? 600 : 400;
                        color: item.path == root.active-path ? Tokens.accent-hover : Tokens.text-primary;
                        vertical-alignment: center;
                    }
                }

                TouchArea {
                    clicked => { root.item-clicked(item.path) }
                    mouse-cursor: pointer;
                }
            }

            // Spacer between sections
            Rectangle { height: 8px; }

            // Devices header
            Text {
                text: "Devices";
                font-size: Tokens.font-xs;
                font-weight: 700;
                color: Tokens.text-secondary;
                letter-spacing: 0.5px;
                x: 10px;
            }

            // Devices items
            for item in root.items : Rectangle {
                visible: item.section == "devices";
                height: 30px;
                border-radius: 6px;
                background: item.path == root.active-path ? Tokens.bg-hover : transparent;

                HorizontalBox {
                    padding-left: 10px;
                    spacing: 8px;

                    Text {
                        text: item.icon;
                        font-size: Tokens.font-lg;
                        vertical-alignment: center;
                    }
                    Text {
                        text: item.name;
                        font-size: Tokens.font-md;
                        font-weight: item.path == root.active-path ? 600 : 400;
                        color: item.path == root.active-path ? Tokens.accent-hover : Tokens.text-primary;
                        vertical-alignment: center;
                    }
                }

                TouchArea {
                    clicked => { root.item-clicked(item.path) }
                    mouse-cursor: pointer;
                }
            }
        }
    }
}

// ─── Toolbar ────────────────────────────────────────────────────────────────

component Toolbar {
    in property <string> current-path;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> search-text;

    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);

    height: 48px;

    Rectangle {
        background: Tokens.bg-toolbar;

        // Bottom border
        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding: 8px;
            spacing: 6px;

            // Back
            Button {
                text: "‹";
                enabled: root.can-go-back;
                clicked => { root.go-back() }
            }
            // Forward
            Button {
                text: "›";
                enabled: root.can-go-forward;
                clicked => { root.go-forward() }
            }
            // Up
            Button {
                text: "⌃";
                clicked => { root.go-up() }
            }

            // Path bar
            LineEdit {
                text: root.current-path;
                placeholder-text: "/path/to/directory";
                accepted(text) => { root.path-entered(text) }
                horizontal-stretch: 1;
            }

            // Search
            LineEdit {
                text: root.search-text;
                placeholder-text: "Search files…";
                min-width: 140px;
                preferred-width: 220px;
                edited(text) => { root.search-changed(text) }
            }
        }
    }
}

// ─── File List ──────────────────────────────────────────────────────────────

component FileList {
    in property <[FileEntry]> files;
    in property <int> selected-index: -1;
    in property <string> sort-column: "name";
    in property <bool> sort-ascending: true;

    callback file-selected(int);
    callback file-activated(int);
    callback sort-requested(string);

    VerticalBox {
        padding: 0;
        spacing: 0;

        // Column headers (fixed height)
        Rectangle {
            height: 30px;
            background: Tokens.bg-header;

            // Bottom border
            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Tokens.border-subtle;
            }

            HorizontalBox {
                padding-left: 14px;
                spacing: 0;

                // Name
                Rectangle {
                    horizontal-stretch: 3;
                    Text {
                        text: "Name";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => { root.sort-requested("name") }
                        mouse-cursor: pointer;
                    }
                }

                // Size
                Rectangle {
                    min-width: 70px;
                    preferred-width: 90px;
                    Text {
                        text: "Size";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => { root.sort-requested("size") }
                        mouse-cursor: pointer;
                    }
                }

                // Modified
                Rectangle {
                    min-width: 100px;
                    preferred-width: 150px;
                    Text {
                        text: "Date Modified";
                        font-size: Tokens.font-sm;
                        font-weight: 600;
                        color: Tokens.text-secondary;
                        horizontal-alignment: right;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => { root.sort-requested("modified") }
                        mouse-cursor: pointer;
                    }
                }
            }
        }

        // File entries (fill remaining space)
        VerticalBox {
            padding: 0;
            spacing: 0;
            vertical-stretch: 1;

            for entry[index] in root.files : Rectangle {
                min-height: 28px;
                vertical-stretch: 0;

                // Background
                Rectangle {
                    background: index == root.selected-index
                        ? Tokens.accent
                        : (mod(index, 2) == 0 ? Tokens.bg-window : Tokens.bg-row-alt);
                }

                // Content overlay (same size as background)
                Rectangle {
                    HorizontalBox {
                        padding-left: 14px;
                        spacing: 8px;

                        // Icon + Name
                        HorizontalBox {
                            spacing: 8px;
                            horizontal-stretch: 3;

                            Text {
                                text: entry.icon;
                                font-size: Tokens.font-lg;
                                vertical-alignment: center;
                            }
                            Text {
                                text: entry.name;
                                font-size: Tokens.font-md;
                                font-weight: 500;
                                color: index == root.selected-index ? Tokens.text-on-accent : Tokens.text-primary;
                                overflow: elide;
                                vertical-alignment: center;
                            }
                        }

                        // Size
                        Text {
                            text: entry.size;
                            font-size: Tokens.font-sm;
                            color: index == root.selected-index ? Tokens.text-primary : Tokens.text-secondary;
                            horizontal-alignment: right;
                            min-width: 70px;
                            preferred-width: 90px;
                            vertical-alignment: center;
                        }

                        // Modified
                        Text {
                            text: entry.modified;
                            font-size: Tokens.font-sm;
                            color: index == root.selected-index ? Tokens.text-primary : Tokens.text-secondary;
                            horizontal-alignment: right;
                            min-width: 100px;
                            preferred-width: 150px;
                            vertical-alignment: center;
                        }
                    }

                    // Touch overlay (covers entire row)
                    TouchArea {
                        clicked => { root.file-selected(index) }
                        double-clicked => { root.file-activated(index) }
                        mouse-cursor: pointer;
                    }
                }
            }
        }
    }
}

// ─── Status Bar ─────────────────────────────────────────────────────────────

component StatusBar {
    in property <int> item-count;
    in property <string> status-message;

    height: 26px;

    Rectangle {
        background: Tokens.bg-status;

        // Top border
        Rectangle {
            height: 1px;
            background: Tokens.border-subtle;
        }

        HorizontalBox {
            padding-left: 14px;
            padding-right: 14px;

            Text {
                text: "\{root.item-count} items";
                font-size: Tokens.font-xs;
                color: Tokens.text-secondary;
                vertical-alignment: center;
            }

            Text {
                text: root.status-message;
                font-size: Tokens.font-xs;
                color: Tokens.text-secondary;
                horizontal-alignment: right;
                vertical-alignment: center;
            }
        }
    }
}

// ─── Main Window ────────────────────────────────────────────────────────────

export component MainWindow inherits Window {
    title: "felix";
    min-width: 700px;
    min-height: 450px;
    preferred-width: 1100px;
    preferred-height: 720px;
    background: Tokens.bg-window;

    // Properties
    in property <string> current-path: "/home";
    in property <[FileEntry]> files: [];
    in property <[SidebarItem]> sidebar-items: [];
    in property <string> sidebar-active-path: "";
    in property <int> selected-index: -1;
    in property <bool> can-go-back: false;
    in property <bool> can-go-forward: false;
    in property <string> search-text: "";
    in property <string> status-message: "";

    // Callbacks
    callback go-back();
    callback go-forward();
    callback go-up();
    callback path-entered(string);
    callback search-changed(string);
    callback sidebar-item-clicked(string);
    callback file-selected(int);
    callback file-activated(int);
    callback sort-requested(string);

    VerticalBox {
        padding: 0;
        spacing: 0;

        Toolbar {
            current-path: root.current-path;
            can-go-back: root.can-go-back;
            can-go-forward: root.can-go-forward;
            search-text: root.search-text;
            go-back => { root.go-back() }
            go-forward => { root.go-forward() }
            go-up => { root.go-up() }
            path-entered(p) => { root.path-entered(p) }
            search-changed(s) => { root.search-changed(s) }
        }

        HorizontalBox {
            padding: 0;
            spacing: 0;
            vertical-stretch: 1;

            Sidebar {
                items: root.sidebar-items;
                active-path: root.sidebar-active-path;
                item-clicked(p) => { root.sidebar-item-clicked(p) }
            }

            // Divider
            Rectangle {
                width: 1px;
                background: Tokens.border;
            }

            FileList {
                files: root.files;
                selected-index: root.selected-index;
                horizontal-stretch: 1;
                file-selected(i) => { root.file-selected(i) }
                file-activated(i) => { root.file-activated(i) }
                sort-requested(col) => { root.sort-requested(col) }
            }
        }

        StatusBar {
            item-count: root.files.length;
            status-message: root.status-message;
        }
    }
}

// ─── First Launch Setup Dialog ──────────────────────────────────────────────

export component SetupDialog inherits Dialog {
    title: "felix — First Launch Setup";
    min-width: 400px;
    min-height: 350px;
    preferred-width: 500px;
    preferred-height: 400px;
    background: Tokens.bg-window;

    in-out property <bool> enable-markdown: true;
    in-out property <bool> enable-pdf: true;
    in-out property <bool> enable-docx: false;
    in-out property <bool> enable-pptx: false;

    callback setup-complete();

    VerticalBox {
        padding: 32px;
        spacing: 20px;

        Text {
            text: "Welcome to felix";
            font-size: 24px;
            font-weight: 700;
            color: Tokens.text-primary;
            horizontal-alignment: center;
        }

        Text {
            text: "Choose which built-in tools to enable.\nYou can change these later in settings.";
            font-size: Tokens.font-md;
            color: Tokens.text-secondary;
            horizontal-alignment: center;
        }

        // Spacer
        Rectangle { height: 8px; }

        // Tool toggles
        VerticalBox {
            spacing: 12px;

            HorizontalBox {
                spacing: 12px;
                CheckBox {
                    checked: root.enable-markdown;
                    toggled => { root.enable-markdown = self.checked }
                }
                Text {
                    text: "Markdown viewer/editor";
                    vertical-alignment: center;
                    font-size: Tokens.font-lg;
                    color: Tokens.text-primary;
                }
            }

            HorizontalBox {
                spacing: 12px;
                CheckBox {
                    checked: root.enable-pdf;
                    toggled => { root.enable-pdf = self.checked }
                }
                Text {
                    text: "PDF viewer";
                    vertical-alignment: center;
                    font-size: Tokens.font-lg;
                    color: Tokens.text-primary;
                }
            }

            HorizontalBox {
                spacing: 12px;
                CheckBox {
                    checked: root.enable-docx;
                    toggled => { root.enable-docx = self.checked }
                }
                Text {
                    text: "DOCX viewer/editor";
                    vertical-alignment: center;
                    font-size: Tokens.font-lg;
                    color: Tokens.text-primary;
                }
            }

            HorizontalBox {
                spacing: 12px;
                CheckBox {
                    checked: root.enable-pptx;
                    toggled => { root.enable-pptx = self.checked }
                }
                Text {
                    text: "PPTX viewer/editor";
                    vertical-alignment: center;
                    font-size: Tokens.font-lg;
                    color: Tokens.text-primary;
                }
            }
        }

        // Spacer
        Rectangle { vertical-stretch: 1; }

        Button {
            text: "Get Started";
            primary: true;
            clicked => { root.setup-complete() }
        }
    }
}
